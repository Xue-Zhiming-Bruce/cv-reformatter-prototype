.env
.venv/
.venv-*/
.test_deps/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
*.egg-info/

# Local candidate data and generated artifacts may contain personal data.
data/input_samples/*
data/output_samples/*
data/generated_outputs/*
!data/input_samples/.gitkeep
!data/output_samples/.gitkeep
!data/generated_outputs/.gitkeep

# Local dataset archives may contain resumes or personal data.
tests/*.zip

# Local resume datasets may contain real candidate data. Keep structure docs only.
tests/local_datasets/*
!tests/local_datasets/README.md

# Generated local test run reports.
tests/test_results/*
!tests/test_results/.gitkeep
