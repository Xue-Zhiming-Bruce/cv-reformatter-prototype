# Copy to .env for local development. Never commit .env.
LLM_PROVIDER=openai

# Generic fallback settings. Stage-specific settings below override these.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Candidate extraction stage.
OPENAI_EXTRACT_API_KEY=
OPENAI_EXTRACT_MODEL=gpt-4.1-mini
ANTHROPIC_EXTRACT_API_KEY=
ANTHROPIC_EXTRACT_MODEL=claude-3-5-sonnet-latest

# Future stages can use separate credentials/models when implemented.
OPENAI_REVIEW_API_KEY=
OPENAI_REVIEW_MODEL=gpt-4.1-mini
OPENAI_FOLLOWUP_API_KEY=
OPENAI_FOLLOWUP_MODEL=gpt-4.1-mini
